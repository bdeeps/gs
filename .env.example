DATABASE_URL=postgresql://postgres:postgres@localhost:5432/gurbani
OPENAI_API_KEY=sk-your-openai-key
HF_API_KEY=hf-your-huggingface-key
EMBEDDING_MODEL=intfloat/multilingual-e5-large
# Optional override (default is Hugging Face router hf-inference):
# HF_INFERENCE_BASE_URL=https://router.huggingface.co/hf-inference
PG_POOL_MAX=5

# Optional seed inputs:
# SHABADOS_SQLITE_PATH=./data/shabados.sqlite
# SHABADOS_JSON_PATH=./data/sggs-lines.json
# Defaults to the official stable ShabadOS SQLite release if omitted:
SHABADOS_DOWNLOAD_URL=https://github.com/shabados/database/releases/download/4.8.7/database.sqlite
# SEED_LIMIT=100
